---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjetsHeroLegacy from "../../components/projets/ProjetsHeroLegacy.astro";
import ProjetsHeroLottie from "../../components/projets/ProjetsHeroLottie.astro";

/** Toggle projets hero: `false` = video-sync CSS titles; `true` = designer Lottie overlay. */
const USE_LOTTIE_PROJETS_HERO = true;

const projetsVideoSrc =
  import.meta.env.PUBLIC_PROJETS_VIDEO_URL ?? "/projets.mp4";
---

<BaseLayout
  title="Projets - Rochat Solaire"
  isDark={true}
  orbitNavColorMode="light"
  showBack={true}
>
  <main class="projets-page">
    {
      USE_LOTTIE_PROJETS_HERO ? (
        <ProjetsHeroLottie videoSrc={projetsVideoSrc} />
      ) : (
        <ProjetsHeroLegacy videoSrc={projetsVideoSrc} />
      )
    }
  </main>
</BaseLayout>

<style>
  .projets-page {
    font-family: var(--font-primary);
    margin: 0;
    padding: 0;
    min-height: 100dvh;
    min-height: 100vh;
  }
</style>
