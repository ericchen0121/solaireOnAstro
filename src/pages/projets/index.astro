---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projets - Rochat Solaire"
  isDark={true}
  orbitNavColorMode="light"
  showBack={true}
>
  <main class="projets-page">
    <section class="projets-section bg-black overflow-hidden">
      <video
        id="projets-video"
        autoplay
        loop
        muted
        playsinline
        webkit-playsinline=""
        preload="auto"
        class="projets-video"
      >
        <source src="/projets.mp4" type="video/mp4" />
      </video>
      <div id="projets-text-overlay" class="projets-text-overlay">
        <div class="projets-text-slot">
          <span class="projets-text" data-projets-role="current"></span>
          <span class="projets-text" data-projets-role="next"></span>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .projets-page {
    font-family: var(--font-primary);
    margin: 0;
    padding: 0;
    /* Keeps body background continuous when hero is position:fixed */
    min-height: 100dvh;
    min-height: 100vh;
  }

  /* Full-bleed to physical edges on iPhone (notch / home indicator) with viewport-fit=cover */
  .projets-section {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    min-height: -webkit-fill-available;
    --projets-title-line-height: 115px;
  }

  .projets-video {
    position: absolute;
    object-fit: cover;
    z-index: 0;
    /* iOS Safari: promote compositing layer to avoid black / no-paint frames */
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
    /* Extend past safe-area padding so video reaches hardware edges in landscape */
    top: calc(-1 * env(safe-area-inset-top, 0px));
    bottom: calc(-1 * env(safe-area-inset-bottom, 0px));
    left: calc(-1 * env(safe-area-inset-left, 0px));
    right: calc(-1 * env(safe-area-inset-right, 0px));
    width: calc(
      100% + env(safe-area-inset-left, 0px) + env(safe-area-inset-right, 0px)
    );
    height: calc(
      100% + env(safe-area-inset-top, 0px) + env(safe-area-inset-bottom, 0px)
    );
  }

  .projets-text-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 10;
  }

  .projets-text-slot {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .projets-text-slot .projets-text {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .projets-text[data-projets-role="current"] {
    z-index: 0;
  }

  .projets-text[data-projets-role="next"] {
    z-index: 1;
  }

  .projets-text {
    font-family:
      "F37Moon",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      sans-serif;
    font-weight: 600;
    font-style: normal;
    font-size: 240px;
    line-height: var(--projets-title-line-height);
    letter-spacing: 0.02em; /* 2% */
    color: white;
    text-align: center;
    opacity: 0;
    transform: translateY(var(--projets-title-line-height));
    transition:
      /* opacity 0.2s ease-out, */ transform 0.35s
      cubic-bezier(0.22, 1, 0.36, 1);
  }

  .projets-text.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Move up then disappear (content swap); no opacity transition */
  .projets-text.leaving {
    opacity: 1;
    transform: translateY(calc(-1.55 * var(--projets-title-line-height)));
    transition: transform 0.1s ease-out;
  }

  @media (max-width: 1024px) {
    .projets-section {
      --projets-title-line-height: 60px;
    }

    .projets-text {
      font-size: 120px;
    }
  }

  @media (max-width: 768px) {
    .projets-section {
      --projets-title-line-height: 32px;
    }

    .projets-text {
      font-size: 64px;
    }
  }

  @media (max-width: 480px) {
    .projets-section {
      --projets-title-line-height: 26px;
    }

    .projets-text {
      font-size: 48px;
    }
  }
</style>

<script>
  import { tryPlayVideo } from "../../utils/ensureVideoPlayback";

  const texts = ["Industriel", "Résidentiel", "École", "Rural", "Hôpital"];
  const leaveDuration = 140;
  const enterDelay = 140;
  const segmentLeadTime = 0.3;

  let cleanup: (() => void) | null = null;
  let currentIndex = 0;
  let videoDuration = 0;
  let intervalDuration = 0;
  let currentTextEl: HTMLSpanElement | null = null;
  let nextTextEl: HTMLSpanElement | null = null;

  function getLeavingTransformValue(element: HTMLSpanElement) {
    const lineHeight =
      getComputedStyle(element)
        .getPropertyValue("--projets-title-line-height")
        .trim() || getComputedStyle(element).lineHeight;

    return `translateY(-${lineHeight})`;
  }

  function updateText(index: number) {
    if (!currentTextEl || !nextTextEl) return;
    const isFirstShow =
      !currentTextEl.classList.contains("active") || !currentTextEl.textContent;

    if (isFirstShow) {
      currentTextEl.textContent = texts[index];
      currentTextEl.classList.remove("leaving");
      currentTextEl.classList.remove("active");
      void currentTextEl.offsetHeight;
      currentTextEl.classList.add("active");
      return;
    }

    nextTextEl.textContent = texts[index];
    nextTextEl.style.transition = "";
    nextTextEl.style.opacity = "";
    nextTextEl.style.transform = "";
    nextTextEl.classList.remove("leaving", "active");
    void nextTextEl.offsetHeight;

    currentTextEl.classList.add("leaving");
    currentTextEl.classList.remove("active");
    setTimeout(() => {
      nextTextEl?.classList.add("active");
    }, enterDelay);

    setTimeout(() => {
      const leavingEl = currentTextEl;
      const incomingEl = nextTextEl;
      if (!leavingEl || !incomingEl) return;
      leavingEl.style.transition = "none";
      leavingEl.style.opacity = "0";
      leavingEl.style.transform = getLeavingTransformValue(leavingEl);
      leavingEl.classList.remove("leaving");
      currentTextEl = incomingEl;
      nextTextEl = leavingEl;
      currentTextEl.setAttribute("data-projets-role", "current");
      nextTextEl.setAttribute("data-projets-role", "next");
    }, leaveDuration);
  }

  function initProjetsPage() {
    cleanup?.();
    cleanup = null;

    const video = document.getElementById(
      "projets-video",
    ) as HTMLVideoElement | null;
    currentTextEl = document.querySelector<HTMLSpanElement>(
      ".projets-text[data-projets-role='current']",
    );
    nextTextEl = document.querySelector<HTMLSpanElement>(
      ".projets-text[data-projets-role='next']",
    );

    if (!video || !currentTextEl || !nextTextEl) return;

    const v = video;

    currentIndex = 0;
    videoDuration = 0;
    intervalDuration = 0;

    const ac = new AbortController();
    cleanup = () => ac.abort();

    function syncTextWithVideo() {
      if (videoDuration === 0) return;
      const currentTime = v.currentTime;
      const adjustedTime = (currentTime + segmentLeadTime) % videoDuration;
      const segmentIndex = Math.floor(adjustedTime / intervalDuration);
      const newIndex = Math.min(segmentIndex, texts.length - 1);

      if (newIndex !== currentIndex) {
        currentIndex = newIndex;
        updateText(currentIndex);
      }
    }

    function onLoadedMetadata() {
      videoDuration = v.duration;
      if (!Number.isFinite(videoDuration) || videoDuration <= 0) return;
      intervalDuration = videoDuration / 5;
      currentIndex = 0;
      updateText(0);
      tryPlayVideo(v);
    }

    v.addEventListener("loadedmetadata", onLoadedMetadata, {
      signal: ac.signal,
    });
    v.addEventListener("timeupdate", syncTextWithVideo, {
      signal: ac.signal,
    });
    v.addEventListener(
      "ended",
      () => {
        currentIndex = 0;
        updateText(0);
      },
      { signal: ac.signal },
    );

    tryPlayVideo(v);

    if (v.readyState >= 2 && Number.isFinite(v.duration) && v.duration > 0) {
      videoDuration = v.duration;
      intervalDuration = videoDuration / 5;
      updateText(0);
    }
  }

  document.addEventListener("astro:page-load", initProjetsPage);
  initProjetsPage();
</script>
