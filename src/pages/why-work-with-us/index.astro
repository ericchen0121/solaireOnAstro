---
import LenisLayout from "../../layouts/LenisLayout.astro";
---

<LenisLayout
  title="Pourquoi travailler avec nous? - Rochat Solaire"
  isDark={false}
  orbitNavColorMode="dark"
>
  <main class="why-us-page">
    <!-- Top Section - 100vh -->
    <section
      class="why-us-section h-screen bg-white text-black flex items-center justify-center"
    >
      <div class="top-section-content">
        <h3 class="typo-h3 mt-20 mb-16 md:mt-28 md:mb-20 lg:mt-40 lg:mb-24">
          Des partenaires dynamiques, en mesure de réaliser tous les projets
          photovoltaïques.
        </h3>

        <h3 class="typo-h3 mt-0 mb-16 md:mb-20 lg:mb-24">
          Sociétés affiliées: Palézieux Solaire SA, Bettens Solaire Sàrl.
        </h3>

        <h3 class="typo-h3 mt-0 mb-16 md:mb-20 lg:mb-24">
          On fait ce que l'on dit, et disons ce que l'on fait!
        </h3>
      </div>
    </section>

    <!-- Numbered List Section -->
    <section class="numbered-list-section bg-white text-black py-20 md:py-32">
      <div class="numbered-list-content">
        <!-- Numbered List -->
        <ol class="numbered-list space-y-8 md:space-y-12">
          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">1</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous gérons 9 centrales photovoltaïques propres qui produisent 2.4
              millions de kWh par année.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">2</h2>
            </div>
            <p class="numbered-text typo-b1">
              Membre de Swissolar, RochatSolaire fait partie des Pros du
              Solaire.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">3</h2>
            </div>
            <p class="numbered-text typo-b1">
              Elle exécute des mandats pour des collectivités publiques, ou des
              privés, étude du projet photovoltaïque, optimisation, rédaction du
              cahier des charges de l'appel d'offres, choix des fournisseurs,
              surveillance des travaux et contrôle de la performance.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">4</h2>
            </div>
            <p class="numbered-text typo-b1">
              Elle offre des opportunités de placement financier à des
              investisseurs.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">5</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous cherchons à bien comprendre les besoins du client, ses
              objectifs et ses ressources.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">6</h2>
            </div>
            <p class="numbered-text typo-b1">
              Notre logiciel financier exclusif permet de calculer tous les
              paramètres du projet et son rendement.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">7</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous pouvons aider le client à financer son investissement auprès
              d'une banque.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number m-0">8</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous effectuons ou faisons effectuer les démarches auprès des
              entités officielles, communes, cantons, Swissgrid, Office Fédéral
              du Courant Fort (ESTI), distributeur local d'électricité.
            </p>
          </li>
        </ol>
      </div>
    </section>
  </main>
</LenisLayout>

<style>
  .why-us-page {
    font-family: var(--font-primary);
  }

  .why-us-section {
    /* Normal scrolling - no section snap */
    scroll-behavior: smooth;
  }

  /* Top Section Content Container */
  .top-section-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (min-width: 768px) {
    .top-section-content {
      max-width: 1400px;
      padding: 0 4rem;
    }
  }

  /* Numbered List Content Container */
  .numbered-list-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (min-width: 768px) {
    .numbered-list-content {
      max-width: 1400px;
      padding: 0 4rem;
    }
  }

  .numbered-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .numbered-item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .numbered-item {
      gap: 4rem;
      margin-bottom: 5rem;
    }
  }

  .number-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-shrink: 0;
    min-width: 48px;
    padding-top: 0;
    margin-top: 0;
    align-self: flex-start;
  }

  @media (min-width: 768px) {
    .number-container {
      min-width: 72px;
    }
  }

  @media (min-width: 1024px) {
    .number-container {
      min-width: 108px;
    }
  }

  /* .typo-h2 on digits — tight line box for alignment with b1 copy */
  .number.typo-h2 {
    line-height: 1;
    text-align: center;
    width: 100%;
    display: block;
  }

  .numbered-text {
    width: 50%;
    text-align: left;
    margin: 0;
    padding-top: 0;
    margin-top: 0;
  }
</style>
