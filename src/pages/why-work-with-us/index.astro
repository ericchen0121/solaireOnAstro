---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Pourquoi travailler avec nous? - Rochat Solaire"
  isDark={false}
  orbitNavColorMode="dark"
>
  <main class="why-us-page">
    <!-- Top Section - 100vh -->
    <section
      class="why-us-section md:min-h-screen bg-white text-black flex items-start justify-center md:items-center pt-[max(1.125rem,calc(env(safe-area-inset-top,0px)+0.625rem))] pb-6 md:pt-0 md:pb-0"
    >
      <div class="top-section-content">
        <h3 class="typo-h3 mt-0 mb-10 md:mt-28 md:mb-20 lg:mt-40 lg:mb-24">
          Des partenaires dynamiques, en mesure de réaliser tous les projets
          photovoltaïques.
        </h3>

        <h3 class="typo-h3 mt-0 mb-10 md:mb-20 lg:mb-24">
          Sociétés affiliées: Palézieux Solaire SA, Bettens Solaire Sàrl.
        </h3>

        <h3 class="typo-h3 mt-0 mb-2 md:mb-20 lg:mb-24">
          On fait ce que l'on dit, et disons ce que l'on fait!
        </h3>
      </div>
    </section>

    <!-- Numbered List Section -->
    <section
      class="numbered-list-section bg-white text-black pt-9 pb-20 md:py-32"
    >
      <div class="top-section-content">
        <!-- Numbered List -->
        <ol class="numbered-list space-y-5 md:space-y-7 lg:space-y-8">
          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">1</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous gérons 9 centrales photovoltaïques propres qui produisent 2.4
              millions de kWh par année.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">2</h2>
            </div>
            <p class="numbered-text typo-b1">
              Membre de Swissolar, RochatSolaire fait partie des Pros
              du&nbsp;Solaire.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">3</h2>
            </div>
            <p class="numbered-text typo-b1">
              Elle exécute des mandats pour des collectivités publiques ou des
              privés: étude du projet photovoltaïque, optimisation, rédaction du
              cahier des charges de l'appel d'offres, choix des fournisseurs,
              surveillance des travaux et contrôle de la performance.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">4</h2>
            </div>
            <p class="numbered-text typo-b1">
              Elle offre des opportunités de placement financier à des
              investisseurs.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">5</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous cherchons à bien comprendre les besoins du client, ses
              objectifs et ses ressources.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">6</h2>
            </div>
            <p class="numbered-text typo-b1">
              Notre logiciel financier exclusif permet de calculer tous les
              paramètres du projet et son rendement.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">7</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous pouvons aider le client à financer son investissement auprès
              d'une banque.
            </p>
          </li>

          <li class="numbered-item">
            <div class="number-container">
              <h2 class="typo-h2 number">8</h2>
            </div>
            <p class="numbered-text typo-b1">
              Nous effectuons ou faisons effectuer les démarches auprès des
              entités officielles, communes, cantons, Swissgrid, Office Fédéral
              du Courant Fort (ESTI), distributeur local d'électricité.
            </p>
          </li>
        </ol>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .why-us-page {
    font-family: var(--font-primary);
  }

  .why-us-section {
    /* Normal scrolling - no section snap */
    scroll-behavior: smooth;
  }

  .numbered-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Tighter leading than site b1 (130%); pretty wrap reduces lone short last lines where supported */
  .numbered-list .numbered-text {
    line-height: 1.22;
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .numbered-list .numbered-text {
      line-height: 1.2;
    }
  }

  /*
   * Tight line box; nudge numeral up on wide viewports only.
   * clamp(MIN, preferred, MAX) needs MIN ≤ MAX. 0.5vh is never negative, so it could never yield -12px.
   * Here: ~0 from narrow up to --num-nudge-start, then ramp to -12px by --num-nudge-end.
   */
  .numbered-list .number.typo-h2 {
    line-height: 1;
    text-align: center;
    width: 100%;
    display: block;
    margin: 0;
    --num-nudge-start: 480px;
    --num-nudge-end: 1280px;
    margin-top: clamp(
      -12px,
      calc(
        -12px * (100vw - var(--num-nudge-start)) /
          (var(--num-nudge-end) - var(--num-nudge-start))
      ),
      0px
    );
  }
</style>
