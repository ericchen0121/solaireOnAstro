---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.tsx";

export const prerender = false;
---

<BaseLayout
  title="Contact Us - Rochat Solaire"
  isDark={true}
  orbitNavColorMode="light"
  showBack={true}
>
  <main class="contact-page">
    <section class="contact-section bg-black text-white py-16 md:py-20">
      <div class="container mx-auto px-4 md:px-[4.5rem]">
        <div class="contact-page-fade mx-auto max-w-3xl">
          <ContactForm client:only="react">
            <p
              slot="fallback"
              class="font-f37moon-light text-sm tracking-[0.02em] text-white/50"
            >
              Loading form…
            </p>
          </ContactForm>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-page {
    font-family: var(--font-primary);
  }

  /* Hero-adjacent type scale — :global so React island (ContactForm) receives rules */
  :global(.contact-type-title) {
    position: relative;
    font-family: var(--font-hero);
    font-weight: 300;
    font-size: clamp(32px, 5.5vw, 52px);
    line-height: 1.08;
    letter-spacing: 0.02em;
  }

  :global(.contact-type-title .hero-word),
  :global(.contact-subject-reveal .hero-word),
  :global(.contact-email-reveal .hero-word),
  :global(.contact-message-reveal .hero-word) {
    display: inline-block;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    :global(.contact-type-title) {
      font-size: clamp(28px, 6vw, 36px);
      line-height: 1.12;
    }
  }

  .contact-page-fade {
    opacity: 0;
    transform: translateY(12px);
    animation: contact-page-fade-in 0.65s ease-out forwards;
  }

  @keyframes contact-page-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-page-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  /* Chrome autofill paints a light background; force dark field to match page */
  :global(.contact-page .contact-form-type input:-webkit-autofill),
  :global(.contact-page .contact-form-type input:-webkit-autofill:hover),
  :global(.contact-page .contact-form-type input:-webkit-autofill:focus),
  :global(.contact-page .contact-form-type input:-webkit-autofill:active),
  :global(.contact-page .contact-form-type textarea:-webkit-autofill),
  :global(.contact-page .contact-form-type textarea:-webkit-autofill:hover),
  :global(.contact-page .contact-form-type textarea:-webkit-autofill:focus),
  :global(.contact-page .contact-form-type textarea:-webkit-autofill:active) {
    -webkit-box-shadow: 0 0 0 1000px rgb(0 0 0) inset !important;
    -webkit-text-fill-color: rgb(255 255 255) !important;
    caret-color: white;
  }
</style>

<style is:global>
  @keyframes contact-feedback-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
