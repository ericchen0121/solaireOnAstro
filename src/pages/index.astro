---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rochat Solaire - Home"
  isDark={true}
  orbitNavColorMode="light"
>
  <!-- Section 1: Headline -->
  <section
    id="hero-trigger"
    class="hero h-screen flex items-center justify-center bg-black text-white"
  >
    <div
      id="hero-content"
      class="w-full min-w-0 box-border px-[4.5rem] md:px-[8rem]"
    >
      <h2
        class="font-f37moon-light hero-title typo-h2 mx-auto min-w-0 w-full max-w-6xl text-center"
      >
        <span class="hero-cursor" aria-hidden="true"></span>
        <span class="hero-headline"
          >Le soleil produit en une heure ce que l'humanité consomme en un an.</span
        >
      </h2>
    </div>
  </section>

  <!-- Section 2: Company Name -->
  <section
    class="company-name-section h-screen flex items-center justify-center bg-black text-white"
  >
    <div class="container w-full px-[4.5rem] md:px-[8rem]">
      <div
        class="company-name-title text-center flex flex-wrap items-baseline justify-center gap-x-2"
      >
        <h4 class="typo-h4 m-0">Rochat</h4>
        <span class="typo-h4-light company-name-solaire">Solaire</span>
      </div>
    </div>
  </section>

  <!-- Section 3: Stats -->
  <section
    class="stats-section relative h-screen min-h-0 flex flex-col items-center justify-center overflow-hidden bg-black text-white py-20 [@media(max-height:560px)]:py-6 [@media(max-height:560px)_and_(max-width:1100px)]:justify-start [@media(max-height:560px)_and_(max-width:1100px)]:overflow-y-auto"
  >
    <div class="container mx-auto px-[4.5rem] md:px-[8rem] w-full">
      <div
        class="stats-grid grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 max-w-7xl mx-auto [@media(max-height:560px)_and_(max-width:1100px)]:grid-cols-1 [@media(max-height:560px)_and_(max-width:1100px)]:gap-8"
      >
        <!-- Stat 1: 1482 -->
        <div class="stat-column">
          <span class="stat-number text-white mb-6 block">1482</span>
          <div class="stat-copy-wrap">
            <p class="stat-copy text-white/90">
              Vinet Rochat exploite le flu des rivières à la vallée de Joux, une
              source d'énergie renouvelable que nous a accordée la nature.
            </p>
          </div>
        </div>

        <!-- Stat 2: 2007 -->
        <div class="stat-column">
          <span class="stat-number text-white mb-6 block">2007</span>
          <div class="stat-copy-wrap">
            <p class="stat-copy text-white/90">
              Dès 2007, pionniers en production d'énergie photovoltaïque,
              conseil, investissement et service clients.
            </p>
          </div>
        </div>

        <!-- Stat 3: 15 -->
        <div class="stat-column">
          <span class="stat-number text-white mb-6 block">15</span>
          <div class="stat-copy-wrap">
            <p class="stat-copy text-white/90">
              Fois plus d'énergie est produite par un module qu'il ne faut pour
              le produire.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Video Background (z-0 so orbit nav stays on top) -->
  <section
    class="video-section relative z-0 h-screen w-screen flex items-center justify-center overflow-hidden bg-black text-center"
  >
    <video
      autoplay
      loop
      muted
      playsinline
      webkit-playsinline=""
      preload="auto"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/romande_r1.mp4" type="video/mp4" />
    </video>

    <div class="relative z-10 w-full px-[4.5rem] md:px-[8rem] text-center">
      <h2 class="typo-h2 text-white no-ligatures">
        Un réseau romand,<br />
        basé sur la confiance.
      </h2>
    </div>
  </section>

  <!-- Section 5 -->
  <section
    id="why-solar-section"
    class="why-solar-section h-screen w-screen flex items-center justify-center bg-black text-white"
  >
    <a href="/why-solar" class="slide-bar-link">
      <h2
        class="slide-bar-title text-center px-[4.5rem] md:px-[8rem] cursor-pointer"
      >
        <span class="slide-bar-bg" aria-hidden="true"></span>
        <span class="slide-bar-text-stack">
          <span id="why-solar-text" class="slide-bar-fill-text"
            >Pourquoi le solaire?</span
          >
        </span>
      </h2>
    </a>
  </section>

  <!-- Section 6 -->
  <section
    id="why-us-section"
    class="why-us-section h-screen w-screen flex items-center justify-center bg-black text-white"
  >
    <a href="/why-work-with-us" class="slide-bar-link">
      <h2
        class="slide-bar-title text-center px-[4.5rem] md:px-[8rem] cursor-pointer"
      >
        <span class="slide-bar-bg" aria-hidden="true"></span>
        <span class="slide-bar-text-stack">
          <span id="why-us-text" class="slide-bar-fill-text"
            >Pourquoi travailler avec nous?</span
          >
        </span>
      </h2>
    </a>
  </section>

  <!-- Section 7 -->
  <section
    id="clients-section"
    class="clients-section h-screen w-screen flex items-center justify-center bg-black text-white"
  >
    <a href="/clients" class="slide-bar-link">
      <h2
        class="slide-bar-title text-center px-[4.5rem] md:px-[8rem] cursor-pointer"
      >
        <span class="slide-bar-bg" aria-hidden="true"></span>
        <span class="slide-bar-text-stack">
          <span id="clients-text" class="slide-bar-fill-text"
            >Qui sont nos clients?</span
          >
        </span>
      </h2>
    </a>
  </section>

  <!-- Section 8: Projets -->
  <section
    id="projets-section"
    class="projets-section h-screen w-screen flex items-center justify-center bg-black text-white"
  >
    <h2 class="typo-h2 font-f37moon-light text-center px-[4.5rem] md:px-[8rem]">
      <a id="projets-text" href="/projets" class="cursor-pointer"> Projets </a>
    </h2>
  </section>

  <!-- Section 9: Contact -->
  <section
    id="contact-section"
    class="contact-section h-screen w-screen flex items-center justify-center bg-black text-white"
  >
    <h2 class="typo-h2 font-f37moon-light text-center px-[4.5rem] md:px-[8rem]">
      <a id="contact-text" href="/contact" class="cursor-pointer">contact</a>
    </h2>
  </section>
</BaseLayout>

<!-- ====================== -->
<!--  NATIVE SCROLL VERSION -->
<!-- ====================== -->

<script>
  // @ts-nocheck
  import {
    HERO_END_CURSOR_BLINK,
    initLetterReveal,
  } from "../animations/letterReveal";
  import { initScrollLetterReveal } from "../animations/scrollLetterReveal";
  import { initStatsSectionReveal } from "../animations/statsSectionReveal";
  import { initVideoSectionScale } from "../animations/videoSectionScale";
  import { initSectionSnap } from "../animations/sectionSnap";
  import { tryPlayVideo } from "../utils/ensureVideoPlayback";
  import { requestOrbitPillSubpageFromPage } from "../animations/orbitNavSubpagePill";

  // Using native browser scrolling for better section snap reliability
  // ScrollTrigger works natively with window scrolling

  if (typeof window !== "undefined") {
    let cleanupSectionSnap = null;
    let cleanupStatsReveal = null;
    let cleanupVideoScale = null;
    let cleanupLetterReveal = null;
    const cleanupFunctions = [];

    const SLIDE_BAR_LINK_SEL = ".slide-bar-link";
    function onSlideBarLinkHoverEnter() {
      if (document.body.classList.contains("section-snap-scrolling")) return;
      document.body.classList.add("nav-or-text-hovered");
    }
    function onSlideBarLinkHoverLeave(e) {
      const rt = e.relatedTarget;
      if (rt instanceof Element && rt.closest(SLIDE_BAR_LINK_SEL)) return;
      document.body.classList.remove("nav-or-text-hovered");
    }
    /** Slide-bar links: teardown hover → body class on beforeunload */
    let slideBarOrbitHoverLinks = [];

    function scrollToHashSectionIfNeeded() {
      const { hash } = window.location;
      if (!hash) return;

      try {
        const target = document.querySelector(hash);
        if (!(target instanceof HTMLElement)) return;

        // Defer to ensure layout is ready before scrolling
        requestAnimationFrame(() => {
          window.scrollTo({
            top: target.offsetTop,
            behavior: "auto",
          });
        });
      } catch (err) {
        console.warn("Hash scroll failed for", hash, err);
      }
    }

    function initAnimations() {
      console.log("🎬 initAnimations called");
      // 1. Letter reveal for hero - MUST run first before any other animations
      // Wait for next frame to ensure DOM is ready
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          console.log("🎬 Calling initLetterReveal");
          cleanupLetterReveal = initLetterReveal(".hero-title", 0.8, 0.05, {
            endCursorBlink: HERO_END_CURSOR_BLINK,
          });

          // 2. Stats section: numbers stagger up, then paragraphs reveal; exit at top on scroll
          cleanupStatsReveal = initStatsSectionReveal();

          // 3. Video section: scale background video from full-screen to ~80% to reveal black border
          cleanupVideoScale = initVideoSectionScale();

          // 4. Section snapping
          cleanupSectionSnap = initSectionSnap({
            threshold: 0.05,
            snapDuration: 0.55,
            ease: "power3.inOut",
            sections: [
              "#hero-trigger",
              ".company-name-section",
              ".stats-section",
              ".video-section",
              ".why-solar-section",
              ".why-us-section",
              ".clients-section",
              ".projets-section",
              ".contact-section",
            ],
          });

          // If we arrived with a hash (e.g. from OrbitNav "back"),
          // gently correct the initial scroll position to that section.
          scrollToHashSectionIfNeeded();
        });
      });

      // 5. Scroll letter reveals (other sections) - MUST come after slide-bar setup
      // Slide-bar links: hover → body.nav-or-text-hovered (OrbitNav V2); click → wipe then navigate
      slideBarOrbitHoverLinks = Array.from(
        document.querySelectorAll(SLIDE_BAR_LINK_SEL),
      );
      console.log(
        "🎯 Found slide-bar-link elements:",
        slideBarOrbitHoverLinks.length,
      );

      slideBarOrbitHoverLinks.forEach((link) => {
        link.addEventListener("mouseenter", onSlideBarLinkHoverEnter);
        link.addEventListener("mouseleave", onSlideBarLinkHoverLeave);
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const href = link.getAttribute("href");
          if (!href) return;

          console.log("🖱️ Slide bar link clicked");
          link.classList.add("active");
          void requestOrbitPillSubpageFromPage();

          /* After .slide-bar-bg transform (0.8s + ease-out tail); keep margin so wipe finishes before hard nav */
          setTimeout(() => {
            console.log("🚀 Navigating to:", href);
            window.location.href = href;
          }, 920);
        });
      });

      // Initialize letter reveals AFTER setting up click handlers
      cleanupFunctions.push(initScrollLetterReveal("#why-solar-text", 0.07));
      cleanupFunctions.push(initScrollLetterReveal("#why-us-text", 0.07));
      cleanupFunctions.push(initScrollLetterReveal("#clients-text", 0.07));
      cleanupFunctions.push(initScrollLetterReveal("#projets-text", 0.1));
      cleanupFunctions.push(initScrollLetterReveal("#contact-text", 0.1));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAnimations);
    } else {
      initAnimations();
    }

    window.addEventListener("beforeunload", () => {
      cleanupLetterReveal?.();
      cleanupSectionSnap?.();
      cleanupStatsReveal?.();
      cleanupVideoScale?.();
      cleanupFunctions.forEach((fn) => fn());
      slideBarOrbitHoverLinks.forEach((link) => {
        link.removeEventListener("mouseenter", onSlideBarLinkHoverEnter);
        link.removeEventListener("mouseleave", onSlideBarLinkHoverLeave);
      });
      slideBarOrbitHoverLinks = [];
    });

    function playHomeVideoIfPresent() {
      const v = document.querySelector(".video-section video");
      if (v instanceof HTMLVideoElement) tryPlayVideo(v);
    }

    document.addEventListener("astro:page-load", playHomeVideoIfPresent);
  }
</script>
