---
import OrbitNav from "../components/react/OrbitNav.tsx";
import ClientRouter from "astro/components/ClientRouter.astro";
import "../styles/global.css";
/* After global — replaces Astro VT fallback keyframes that use plus-lighter (bad on white subpages). */
import "../styles/view-transition-fix.css";

interface Props {
  title?: string;
  description?: string;
  isDark?: boolean;
  orbitNavColorMode?: "auto" | "light" | "dark";
  /** Show "back" on non-home even when nav is light (e.g. projets: light dot, dark bg, white back text). */
  showBack?: boolean;
}

const {
  title = "Rochat Solaire - Solar Energy Solutions",
  description = "Leading solar energy solutions for sustainable power generation.",
  isDark = false,
  orbitNavColorMode = "auto",
  showBack = false,
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class:list={[{ "bg-black min-h-full": isDark }]}
  data-orbit-nav-color-mode={orbitNavColorMode}
  data-orbit-show-back={String(showBack)}
  data-orbit-is-dark={String(isDark)}
>
  <head>
    <ClientRouter fallback="swap" />
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Primary UI fonts — preload before first paint to reduce swap/reflow vs system fallback -->
    <link
      rel="preload"
      href="/fonts/F37Moon-Light/F37Moon-Light.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/F37Moon-Demi/F37Moon-Demi.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <meta name="generator" content={Astro.generator} />
    {/* Enables cross-document View Transitions between same-origin navigations where supported (Chrome 126+); ClientRouter handles internal links. */}
    <meta name="view-transition" content="same-origin" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/og-image.jpg" />

    <!-- Google Fonts - Poppins & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class:list={[{ "bg-black min-h-full": isDark }]}>
    <script define:vars={{ orbitNavColorMode, showBack, isDark }}>
      document.documentElement.dataset.orbitNavColorMode = orbitNavColorMode;
      document.documentElement.dataset.orbitShowBack = String(showBack);
      document.documentElement.dataset.orbitIsDark = String(isDark);
    </script>
    <div
      transition:name="orbit-nav"
      transition:persist="orbit-nav"
      transition:animate="none"
      class="relative z-[9999] overflow-visible"
      style="isolation: isolate;"
    >
      <OrbitNav
        client:only="react"
        isDark={isDark}
        colorMode={orbitNavColorMode}
        showBack={showBack}
      />
    </div>
    <slot />
  </body>
</html>
