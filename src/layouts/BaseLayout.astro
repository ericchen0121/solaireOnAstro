---
import OrbitNav from "../components/react/OrbitNav.tsx";
import ClientRouter from "astro/components/ClientRouter.astro";
import "../styles/global.css";
/* After global — replaces Astro VT fallback keyframes that use plus-lighter (bad on white subpages). */
import "../styles/view-transition-fix.css";

interface Props {
  title?: string;
  description?: string;
  isDark?: boolean;
  orbitNavColorMode?: "auto" | "light" | "dark";
  /** Show "back" on non-home even when nav is light (e.g. projets: light dot, dark bg, white back text). */
  showBack?: boolean;
}

const {
  title = "Rochat Solaire - Solar Energy Solutions",
  description = "Leading solar energy solutions for sustainable power generation.",
  isDark = false,
  orbitNavColorMode = "auto",
  showBack = false,
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class:list={[{ "bg-black min-h-full": isDark }]}
  data-orbit-nav-color-mode={orbitNavColorMode}
  data-orbit-show-back={String(showBack)}
  data-orbit-is-dark={String(isDark)}
>
  <head>
    <ClientRouter fallback="swap" />
    {/* Sync + capture: block ClientRouter SPA swap on subpage → home back; force full reload (GSAP/snap need document load). */}
    <script is:inline>
      (function () {
        var STORAGE_KEY = "sol:lastPath";

        function normPath(pathname) {
          return (pathname || location.pathname).replace(/\/+$/, "") || "/";
        }

        function readStoredPath() {
          try {
            return sessionStorage.getItem(STORAGE_KEY);
          } catch {
            return null;
          }
        }

        function writeStoredPath(path) {
          try {
            sessionStorage.setItem(STORAGE_KEY, path);
          } catch {}
        }

        function isHomeDom() {
          return !!document.querySelector("main.home-page");
        }

        function forceHomeReload() {
          location.replace(location.href);
        }

        function shouldReloadOnBackToHome(fromPath, toPath) {
          return fromPath !== "/" && toPath === "/";
        }

        var trackedPath = normPath();
        writeStoredPath(trackedPath);

        function syncTrackedPath() {
          trackedPath = normPath();
          writeStoredPath(trackedPath);
        }

        var push = history.pushState;
        var replace = history.replaceState;
        history.pushState = function () {
          push.apply(history, arguments);
          syncTrackedPath();
        };
        history.replaceState = function () {
          replace.apply(history, arguments);
          syncTrackedPath();
        };

        function reloadBackToHomeIfNeeded(fromPath) {
          var toPath = normPath();
          trackedPath = toPath;
          writeStoredPath(toPath);
          if (!shouldReloadOnBackToHome(fromPath, toPath)) return false;
          forceHomeReload();
          return true;
        }

        window.addEventListener(
          "popstate",
          function (e) {
            var stored = readStoredPath();
            var fromPath = stored || trackedPath;
            if (reloadBackToHomeIfNeeded(fromPath)) {
              e.stopImmediatePropagation();
              e.stopPropagation();
            }
          },
          true,
        );

        window.addEventListener("pageshow", function (e) {
          if (normPath() !== "/") return;
          /*
           * BFCache restores pre-navigation DOM (.active strip, nav-or-text-hovered, stuck GSAP).
           * Scripts do not re-run — section snap stays broken until a real reload.
           */
          if (e.persisted) {
            location.reload();
            return;
          }
          if (!isHomeDom()) forceHomeReload();
        });
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Primary UI fonts — preload before first paint to reduce swap/reflow vs system fallback -->
    <link
      rel="preload"
      href="/fonts/F37Moon-Light/F37Moon-Light.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/F37Moon-Demi/F37Moon-Demi.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <meta name="generator" content={Astro.generator} />
    {/* Enables cross-document View Transitions between same-origin navigations where supported (Chrome 126+); ClientRouter handles internal links. */}
    <meta name="view-transition" content="same-origin" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/og-image.jpg" />

    <!-- Google Fonts - Poppins & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class:list={[{ "bg-black min-h-full": isDark }]}>
    {/* Before paint: drop stale strip/hover classes when BFCache or fast back nav beat module init. */}
    <script is:inline>
      (function () {
        function resetHomeVisualStateEarly() {
          if (!document.querySelector("main.home-page")) return;
          document.body.classList.remove(
            "nav-or-text-hovered",
            "section-snap-scrolling",
            "strip-nav-departing",
          );
          var links = document.querySelectorAll(
            "a.home-subpage-section-link.active",
          );
          for (var i = 0; i < links.length; i++) {
            links[i].classList.remove("active");
          }
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", resetHomeVisualStateEarly);
        } else {
          resetHomeVisualStateEarly();
        }
      })();
    </script>
    <script define:vars={{ orbitNavColorMode, showBack, isDark }}>
      document.documentElement.dataset.orbitNavColorMode = orbitNavColorMode;
      document.documentElement.dataset.orbitShowBack = String(showBack);
      document.documentElement.dataset.orbitIsDark = String(isDark);
    </script>
    <div
      transition:name="orbit-nav"
      transition:persist="orbit-nav"
      transition:animate="none"
      class="relative z-[9999] overflow-visible"
      style="isolation: isolate;"
    >
      <OrbitNav
        client:only="react"
        isDark={isDark}
        colorMode={orbitNavColorMode}
        showBack={showBack}
      />
    </div>
    <slot />
    {/* Belt-and-suspenders when Astro still starts a back transition (`history.state` present). */}
    <script>
      document.addEventListener("astro:before-preparation", (event) => {
        const ev = event;
        if (ev.direction !== "back" || ev.navigationType !== "traverse") return;
        const toPath = ev.to.pathname.replace(/\/+$/, "") || "/";
        if (toPath !== "/") return;
        const fromPath = ev.from.pathname.replace(/\/+$/, "") || "/";
        if (fromPath === "/") return;
        ev.preventDefault();
      });
    </script>
  </body>
</html>
