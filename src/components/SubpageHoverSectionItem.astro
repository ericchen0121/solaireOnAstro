---
/**
 * One heading + expandable body row (e.g. why-solar, clients). Slot: body (usually `<p class="typo-b1">`; max width from `--subpage-body-copy-max` in global.css).
 */
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<div class="subpage-hover-item">
  <h2 class="typo-h2 subpage-hover-heading">{title}</h2>
  <div class="subpage-hover-detail">
    <div class="subpage-hover-detail-inner">
      <slot />
    </div>
  </div>
</div>
