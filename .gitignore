# build output
dist/
.output/

# Wrangler local deploy metadata (points at dist/; must not be committed — breaks CI)
.wrangler/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# IDE
# .vscode/  # Keep .vscode settings for team consistency
.idea/

# MP4s: Cloudflare Workers max ~25 MiB/file — commit only whitelisted assets in public/.
*.mp4
!public/romande_r1.mp4
!public/projets.mp4

# Local masters / sources — not deployed (Astro only copies public/). README is tracked.
assets-source/**
!assets-source/
!assets-source/README.md
